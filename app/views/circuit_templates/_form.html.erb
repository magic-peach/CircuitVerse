<% if template.errors.any? %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% template.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: template,
    data: { controller: "json-validator", action: "submit->json-validator#submit" } do |f| %>
  <div class="mb-3">
    <%= f.label :name, "Template Name", class: "form-label" %>
    <%= f.text_field :name, class: "form-control form-input", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "Description", class: "form-label" %>
    <%= f.text_area :description, class: "form-control form-input", rows: 3 %>
  </div>

  <div class="mb-3 form-check">
    <%= f.check_box :public, class: "form-check-input" %>
    <%= f.label :public, "Make this template available to all teachers", class: "form-check-label" %>
  </div>

  <div class="mb-3">
    <%= f.label :circuit_data, "Circuit Data (JSON)", class: "form-label" %>
    <% circuit_data_value = template.circuit_data.is_a?(Hash) ? template.circuit_data.to_json : template.circuit_data.to_s %>
    <%= f.text_area :circuit_data, class: "form-control form-input", rows: 6,
        value: circuit_data_value,
        placeholder: '{"components": [], "wires": [], "inputs": [], "outputs": []}',
        data: { json_validator_target: "field", action: "input->json-validator#validate" } %>
    <small class="form-text text-muted">Enter circuit configuration as a JSON object.</small>
  </div>

  <div class="d-flex align-items-center gap-2 mt-4">
    <%= f.submit "Save Template", class: "btn primary-button" %>
    <%= link_to "Cancel", :back, class: "btn mini-button groups-close-mini-button" %>
  </div>
<% end %>
